# Discord bot token (from Discord Developer Portal)
DISCORD_TOKEN=your-bot-token-here

# Your Discord server (guild) ID
GUILD_ID=your-guild-id-here

# ID of the category where ticket channels will be created
CATEGORY_ID=your-category-id-here

# ID of the channel where ticket open/close events are logged
LOGS_CHANNEL_ID=your-logs-channel-id-here

# ID of the channel where the public support panel is posted
PANEL_CHANNEL_ID=your-panel-channel-id-here

# ID of the staff role that can see ticket channels
STAFF_ROLE_ID=your-staff-role-id-here
